#!/bin/sh /etc/rc.common

START=98
STOP=15

USE_PROCD=1
WATCHDOG=/usr/bin/pw2watchdog.sh
SCANNER=/usr/bin/pw2watchdog-scanner.sh
SUBSCRIBE=/usr/bin/pw2watchdog-subscribe.sh

start_service() {
	local enabled
	enabled="$(uci -q get pw2watchdog.main.enabled)"
	[ "$enabled" = "1" ] || {
		logger -t pw2watchdog "Service is disabled, not starting."
		return 0
	}

	mkdir -p /var/run/pw2watchdog

	# Install/update cron hooks for subscription auto-update.
	# Also runs an immediate update if sub_update_on_boot=1.
	# Safe to call every start — idempotent (removes old lines first).
	if [ -x "$SUBSCRIBE" ]; then
		"$SUBSCRIBE" install
		local on_boot
		on_boot="$(uci -q get pw2watchdog.advanced.sub_update_on_boot)"
		if [ "$on_boot" = "1" ]; then
			logger -t pw2watchdog "sub_update_on_boot=1, running subscription update in background"
			"$SUBSCRIBE" run &
		fi
	fi

	procd_open_instance "watchdog"
	procd_set_param command "$WATCHDOG" daemon
	procd_set_param respawn 3600 5 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param file /etc/config/pw2watchdog
	procd_close_instance

	procd_open_instance "scanner"
	procd_set_param command "$SCANNER" daemon
	procd_set_param respawn 3600 5 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param file /etc/config/pw2watchdog
	procd_close_instance
}

stop_service() {
	logger -t pw2watchdog "Service stopped."
}

service_triggers() {
	procd_add_reload_trigger pw2watchdog
}

reload_service() {
	stop
	start
}
