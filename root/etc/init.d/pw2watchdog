#!/bin/sh /etc/rc.common

START=98
STOP=15

USE_PROCD=1
WATCHDOG=/usr/bin/pw2watchdog.sh
SCANNER=/usr/bin/pw2watchdog-scanner.sh
SUBSCRIBE=/usr/bin/pw2watchdog-subscribe.sh

start_service() {
	local enabled
	enabled="$(uci -q get pw2watchdog.main.enabled)"
	[ "$enabled" = "1" ] || {
		logger -t pw2watchdog "Service is disabled, not starting."
		return 0
	}

	mkdir -p /var/run/pw2watchdog

	# Install/update cron hooks for subscription auto-update.
	# Also runs an immediate update if sub_update_on_boot=1.
	# Safe to call every start — idempotent (removes old lines first).
	if [ -x "$SUBSCRIBE" ]; then
		"$SUBSCRIBE" install
		local on_boot
		on_boot="$(uci -q get pw2watchdog.advanced.sub_update_on_boot)"
		if [ "$on_boot" = "1" ]; then
			logger -t pw2watchdog "sub_update_on_boot=1, running subscription update in background"
			"$SUBSCRIBE" run &
		fi
	fi

	procd_open_instance "watchdog"
	procd_set_param command "$WATCHDOG" daemon
	procd_set_param respawn 3600 5 5
	procd_set_param term_timeout 3
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param file /etc/config/pw2watchdog
	procd_close_instance

	procd_open_instance "scanner"
	procd_set_param command "$SCANNER" daemon
	procd_set_param respawn 3600 5 5
	procd_set_param term_timeout 3
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param file /etc/config/pw2watchdog
	procd_close_instance
}

stop_service() {
	logger -t pw2watchdog "Service stopped."
	# Clean up static blackhole nft rule if it was left behind
	local state_file="/var/run/pw2watchdog/state"
	if [ -f "$state_file" ]; then
		local handle
		handle="$(grep 'STATIC_BH_HANDLE' "$state_file" | cut -d"'" -f2)"
		if [ -n "$handle" ] && [ "$handle" != "unknown" ] && [ "$handle" != "" ]; then
			nft delete rule inet passwall2 PSW2_MANGLE handle "$handle" 2>/dev/null && \
				logger -t pw2watchdog "stop_service: removed blackhole nft handle $handle"
		fi
	fi
	# Kill any remaining daemon processes
	killall pw2watchdog.sh pw2watchdog-scanner.sh 2>/dev/null
	sleep 1
}

service_triggers() {
	procd_add_reload_trigger pw2watchdog
}

reload_service() {
	stop
	start
}
